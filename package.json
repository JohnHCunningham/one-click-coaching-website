{
  "name": "one-click-coaching-website",
  "version": "1.0.0",
  "description": "Static website for One Click Coaching",
  "private": true,
  "scripts": {
    "generate-image": "node utils/generate-blog-image.js",
    "build:css": "tailwindcss -i ./styles/main.css -o ./styles/output.css --minify",
    "watch:css": "tailwindcss -i ./styles/main.css -o ./styles/output.css --watch",
    "dev": "npm run watch:css"
  },
  "keywords": [
    "sales",
    "coaching",
    "AI"
  ],
  "author": "John Cunningham",
  "license": "UNLICENSED",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@slack/web-api": "^7.15.2",
    "@vercel/postgres": "^0.10.0",
    "dotenv": "^16.4.5",
    "openai": "^4.77.0",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.16"
  }
}
